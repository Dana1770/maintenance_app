<?xml version="1.0" encoding="utf-8"?>
<!--
  Place this file at:  android/app/src/main/res/xml/network_security_config.xml

  Then add this attribute to <application> in AndroidManifest.xml:
      android:networkSecurityConfig="@xml/network_security_config"
  
  Also make sure AndroidManifest.xml has:
      <uses-permission android:name="android.permission.INTERNET" />
      <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
-->
<network-security-config>
    <!-- Allow cleartext (http://) traffic to any host -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust system CA certificates (handles standard https) -->
            <certificates src="system" />
            <!-- Also trust user-installed certificates (for self-signed certs) -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
